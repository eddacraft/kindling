{
  "name": "@eddacraft/kindling-provider-local",
  "version": "0.2.0",
  "description": "DEPRECATED: use @eddacraft/kindling instead. Local FTS-based retrieval provider for kindling with deterministic, explainable ranking",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "kindling",
    "retrieval",
    "search",
    "fts",
    "full-text-search",
    "ranking",
    "bm25",
    "local-first"
  ],
  "author": "eddacraft <hello@eddacraft.ai>",
  "homepage": "https://github.com/eddacraft/kindling/tree/main/packages/kindling-provider-local#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eddacraft/kindling.git",
    "directory": "packages/kindling-provider-local"
  },
  "bugs": {
    "url": "https://github.com/eddacraft/kindling/issues"
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@eddacraft/kindling-core": "workspace:*",
    "@eddacraft/kindling-store-sqlite": "workspace:*"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
