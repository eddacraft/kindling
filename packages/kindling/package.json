{
  "name": "@eddacraft/kindling",
  "version": "0.2.0",
  "description": "Thin TypeScript client for the Kindling daemon — local memory and continuity engine for AI-assisted development",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schema",
    "bin"
  ],
  "keywords": [
    "kindling",
    "ai",
    "memory",
    "context",
    "llm",
    "agent",
    "continuity",
    "local-first",
    "daemon",
    "client"
  ],
  "author": "EddaCraft <hello@eddacraft.ai>",
  "homepage": "https://github.com/EddaCraft/kindling#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EddaCraft/kindling.git",
    "directory": "packages/kindling"
  },
  "bugs": {
    "url": "https://github.com/EddaCraft/kindling/issues"
  },
  "license": "Apache-2.0",
  "scripts": {
    "sync-types": "node scripts/sync-types.mjs",
    "copy:schema": "node -e \"require('node:fs').mkdirSync('dist/schema',{recursive:true});require('node:fs').copyFileSync('schema/version.json','dist/schema/version.json')\"",
    "build": "tsc --build && pnpm run copy:schema",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
