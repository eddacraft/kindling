{
  "name": "kindling-monorepo",
  "version": "0.3.0",
  "type": "module",
  "private": true,
  "description": "Local memory and continuity engine for AI-assisted development",
  "keywords": [
    "ai",
    "memory",
    "context",
    "llm",
    "agent",
    "continuity",
    "local-first",
    "sqlite",
    "fts",
    "opencode",
    "pocketflow"
  ],
  "author": "eddacraft <hello@eddacraft.ai>",
  "homepage": "https://github.com/eddacraft/kindling#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eddacraft/kindling.git"
  },
  "bugs": {
    "url": "https://github.com/eddacraft/kindling/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "type-check": "pnpm -r run type-check",
    "clean": "pnpm -r run clean && rm -rf node_modules",
    "publish:dry-run": "pnpm run build && pnpm run test && pnpm -r publish --dry-run --no-git-checks",
    "publish:release": "pnpm run build && pnpm run test && pnpm -r publish",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "oxfmt"
    ],
    "*.{json,md,yml,yaml}": [
      "oxfmt"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.45.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "esbuild": ">=0.27.0 <0.27.3",
      "vite": "^7.3.5",
      "rollup": "^4.59.0",
      "postcss": "^8.5.10",
      "flatted": "^3.4.2",
      "js-yaml@4": "^4.2.0",
      "minimatch@9": "^9.0.7",
      "picomatch": "^4.0.4",
      "yaml": "^2.8.3",
      "brace-expansion@2": "^2.0.3"
    }
  }
}
